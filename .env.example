# Server
PORT=4321

# Opcional — modelo de Groq a usar (por defecto: llama-3.3-70b-versatile)
GROQ_MODEL=

# GROQ_API_KEY se agrega a mano en el dashboard de SnapDeploy como
# "Custom Variable" / secreto — a propósito NO está declarada aquí, para
# que no quede expuesta en texto plano en el formulario de auto-detección.
# Clave: https://console.groq.com/keys
