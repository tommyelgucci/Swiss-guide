const cantonOptions = [...CANTONS].sort((a, b) => a.rate100k - b.rate100k);
---
<Layout title={t.pageTitle} lang={lang} description={t.intro}>
  <div class="container">
    <a class="back-link" href={`/${lang}/`}>{t.backHome}</a>
    <h1>{t.heading}</h1>
    <p>{t.intro}</p>
    <p class="quick-answer"><strong>{t.quickAnswer}</strong></p>

    <form id="tax-form" class="card">
      <label>
        {t.grossLabel}
        <input type="range" id="gross" min="2500" max="20000" step="100" value="6000" />
        <output id="gross-output" for="gross">6'000 CHF</output>
      </label>

      <label>
        {t.maritalLabel}
        <select id="marital">
          {t.maritalOptions.map((opt) => <option value={opt.value}>{opt.label}</option>)}
        </select>
      </label>

      <div class="field-row">
        <label>
          {t.ageLabel}
          <input type="number" id="age" min="18" max="70" value="35" />
        </label>
        <label>
          {t.kidsLabel}
          <input type="number" id="kids" min="0" max="6" value="0" />
        </label>
      </div>

      <div class="field-row">
        <label class="checkbox-label">
          <input type="checkbox" id="month13" checked /> {t.month13Label}
        </label>
        <label class="checkbox-label">
          <input type="checkbox" id="church" /> {t.churchLabel}
        </label>
      </div>

      <label>
        {t.cantonListHeading}
        <select id="canton">
          {cantonOptions.map((c) => <option value={c.code}>{c.names[lang] || c.names.en}</option>)}
        </select>
      </label>
    </form>

    <section class="card" id="detail">
      <h2>{t.detailHeading} — <span id="detail-canton"></span></h2>
      <dl class="breakdown">
        <div><dt>{t.grossRow}</dt><dd id="row-gross"></dd></div>
        <div><dt>{t.ahvRow}</dt><dd id="row-ahv"></dd></div>
        <div><dt>{t.bvgRow}</dt><dd id="row-bvg"></dd></div>
        <div><dt>{t.alvRow}</dt><dd id="row-alv"></dd></div>
        <div><dt>{t.taxRow}</dt><dd id="row-tax"></dd></div>
        <div class="net-row"><dt>{t.netRow}</dt><dd id="row-net"></dd></div>
      </dl>
      <p class="net-annual"><span id="net-annual"></span> {t.netAnnualLabel}</p>
    </section>

    <section class="card">
      <h2>{t.cantonListHeading}</h2>
      <input type="search" id="canton-search" placeholder={t.searchPlaceholder} />
      <ol id="canton-ranking" class="canton-ranking"></ol>
    </section>

    <section class="card">
      <h2>{t.pillarHeading}</h2>
      <p>{t.pillarIntro}</p>
      <label>
        {t.pillarContribution}
        <input type="range" id="pillar3a" min="0" max={PILLAR_3A_MAX_2026} step="100" value="6000" />
        <output id="pillar3a-output" for="pillar3a"></output>
      </label>
      <p class="pillar-savings">{t.pillarSavings}: <strong id="pillar-savings-amount"></strong></p>
    </section>

    <section>
      <h2>{t.howHeading}</h2>
      <div class="guide-grid">
        {t.howCards.map((c) => (
          <div class="card">
            <h3>{c.title}</h3>
            <p>{c.text}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="card">
      <h2>{t.quellensteuerHeading}</h2>
      <p>{t.quellensteuerText}</p>
    </section>

    <section>
      <h2>{t.tableHeading}</h2>
      <p>{t.tableIntro}</p>
      <div class="table-scroll">
        <table>
          <thead>
            <tr><th>#</th><th>{t.cantonListHeading}</th><th>~%</th></tr>
          </thead>
          <tbody>
            {cantonOptions.map((c, i) => (
              <tr>
                <td>{i + 1}</td>
                <td>{c.names[lang] || c.names.en}</td>
                <td>{Math.round(c.rate100k * 1000) / 10}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2>{t.leversHeading}</h2>
      <div class="guide-grid">
        {t.levers.map((l) => (
          <div class="card">
            <h3>{l.title}</h3>
            <p>{l.text}</p>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2>{t.faqHeading}</h2>
      {t.faq.map((item) => (
        <details class="faq-item">
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </section>

    <p class="disclaimer">{t.disclaimer} <a href="https://www.estv.admin.ch" target="_blank" rel="noopener">{t.sourceLink}</a></p>
  </div>

  <script type="application/json" id="tax-calc-i18n" set:html={JSON.stringify({ lang, t })} />
</Layout>

<script>
  import { computeBreakdown, pillar3aSavings, rankedCantons } from '../../lib/taxCalculator.js';

  {
    const { lang, t } = JSON.parse(document.getElementById('tax-calc-i18n').textContent);
    const numberFmt = new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 });
    const chf = (n) => `${numberFmt.format(Math.round(n))} CHF`;

    const els = {
      gross: document.getElementById('gross'),
      grossOutput: document.getElementById('gross-output'),
      age: document.getElementById('age'),
      marital: document.getElementById('marital'),
      kids: document.getElementById('kids'),
      month13: document.getElementById('month13'),
      church: document.getElementById('church'),
      canton: document.getElementById('canton'),
      pillar3a: document.getElementById('pillar3a'),
      pillar3aOutput: document.getElementById('pillar3a-output'),
      pillarSavingsAmount: document.getElementById('pillar-savings-amount'),
      search: document.getElementById('canton-search'),
      ranking: document.getElementById('canton-ranking'),
    };

    function currentInputs() {
      return {
        grossMonthly: Number(els.gross.value),
        age: Number(els.age.value) || 35,
        marital: els.marital.value,
        kids: Number(els.kids.value) || 0,
        month13: els.month13.checked,
        church: els.church.checked,
        cantonCode: els.canton.value,
      };
    }

    function render() {
      const inputs = currentInputs();
      els.grossOutput.textContent = chf(inputs.grossMonthly);
      els.gross.setAttribute('aria-valuetext', chf(inputs.grossMonthly));

      const b = computeBreakdown(inputs);
      document.getElementById('detail-canton').textContent = b.canton.names[lang] || b.canton.names.en;
      document.getElementById('row-gross').textContent = chf(b.grossAnnual);
      document.getElementById('row-ahv').textContent = `-${chf(b.ahv)}`;
      document.getElementById('row-bvg').textContent = `-${chf(b.bvg)}`;
      document.getElementById('row-alv').textContent = `-${chf(b.alv + b.nbu)}`;
      document.getElementById('row-tax').textContent = `-${chf(b.tax)} (${b.effectiveRatePct.toFixed(1)}%)`;
      document.getElementById('row-net').textContent = chf(b.netMonthly) + ' ' + t.perMonth;
      document.getElementById('net-annual').textContent = chf(b.netAnnual);

      const pillarContribution = Number(els.pillar3a.value);
      els.pillar3aOutput.textContent = chf(pillarContribution);
      els.pillar3a.setAttribute('aria-valuetext', chf(pillarContribution));
      els.pillarSavingsAmount.textContent = chf(pillar3aSavings(b, pillarContribution));

      const taxableApprox = Math.max(0, b.grossAnnual - b.ahv - b.alv - b.nbu - b.bvg);
      const ranked = rankedCantons(taxableApprox, inputs.marital, inputs.kids, inputs.church);
      const query = (els.search.value || '').toLowerCase();
      els.ranking.innerHTML = '';
      ranked
        .filter((c) => (c.names[lang] || c.names.en).toLowerCase().includes(query))
        .forEach((c, i) => {
          const li = document.createElement('li');
          li.className = c.code === inputs.cantonCode ? 'ranking-item active' : 'ranking-item';
          li.innerHTML = `<span class="ranking-name">${i + 1}. ${c.names[lang] || c.names.en}</span><span class="ranking-rate">${c.ratePct.toFixed(1)}%</span>`;
          li.addEventListener('click', () => {
            els.canton.value = c.code;
            render();
          });
          els.ranking.appendChild(li);
        });
    }

    ['input', 'change'].forEach((evt) => {
      document.getElementById('tax-form').addEventListener(evt, render);
      els.pillar3a.addEventListener(evt, render);
    });
    els.search.addEventListener('input', render);

    render();
  }
</script>

<style>
  .quick-answer {
    background: var(--color-accent-soft);
    border-left: 3px solid var(--color-accent);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-6);
  }
  #tax-form label {
    display: block;
    margin-bottom: var(--space-4);
  }
  #tax-form input[type='range'] {
    width: 100%;
  }
  #tax-form output {
    display: block;
    font-weight: 700;
    font-size: var(--text-lg);
    margin-top: var(--space-1);
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }
  .checkbox-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 500;
  }
  .checkbox-label input {
    width: auto;
    min-height: auto;
  }
  #detail {
    margin-top: var(--space-6);
  }
  .breakdown div {
    display: flex;
    justify-content: space-between;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .breakdown dt {
    color: var(--color-text-secondary);
  }
  .breakdown dd {
    margin: 0;
    font-weight: 600;
  }
  .net-row {
    border-bottom: none !important;
    font-size: var(--text-lg);
    padding-top: var(--space-3) !important;
  }
  .net-row dt,
  .net-row dd {
    color: var(--color-accent);
    font-weight: 700;
  }
  .net-annual {
    text-align: center;
    color: var(--color-text-secondary);
    margin-top: var(--space-2);
  }
  .net-annual span {
    font-weight: 700;
    color: var(--color-text);
  }
  #canton-search {
    margin-bottom: var(--space-3);
  }
  .canton-ranking {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 360px;
    overflow-y: auto;
  }
  :global(.ranking-item) {
    display: flex;
    justify-content: space-between;
    padding: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
  }
  :global(.ranking-item:hover) {
    background: var(--color-bg);
  }
  :global(.ranking-item.active) {
    background: var(--color-accent-soft);
    font-weight: 700;
  }
  .pillar-savings {
    font-size: var(--text-lg);
  }
  .pillar-savings strong {
    color: var(--color-accent);
  }
  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-4);
  }
  .guide-grid .card p {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    margin: 0;
  }
  .table-scroll {
    overflow-x: auto;
  }
