---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  const idiomas = ['es', 'de', 'en', 'fr', 'it', 'pt'];
  return idiomas.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

// Trae solo las guías universales de este idioma
const todasLasGuias = await getCollection('guias-universales');
const guiasDelIdioma = todasLasGuias.filter((g) => g.slug.startsWith(`${lang}/`));

const titulos: Record<string, string> = {
  es: 'Guía para vivir y trabajar en Suiza',
  de: 'Leitfaden für das Leben und Arbeiten in der Schweiz',
  en: 'Guide to living and working in Switzerland',
  fr: 'Guide pour vivre et travailler en Suisse',
  it: 'Guida per vivere e lavorare in Svizzera',
  pt: 'Guia para viver e trabalhar na Suíça',
};

const intros: Record<string, string> = {
  es: 'Guías prácticas escritas para cualquier persona extranjera que llega a Suiza, sin importar tu nacionalidad.',
  de: 'Praktische Leitfäden für alle Ausländer, die in die Schweiz kommen, unabhängig von ihrer Nationalität.',
  en: 'Practical guides written for any foreigner arriving in Switzerland, regardless of nationality.',
  fr: 'Guides pratiques rédigés pour toute personne étrangère arrivant en Suisse, quelle que soit sa nationalité.',
  it: 'Guide pratiche scritte per qualsiasi straniero che arriva in Svizzera, indipendentemente dalla nazionalità.',
  pt: 'Guias práticos escritos para qualquer estrangeiro que chega à Suíça, independentemente da nacionalidade.',
};

const topicOrder = ['tramites', 'trabajo', 'vivienda', 'impuestos', 'salud', 'educacion', 'vivir'];

const topicLabels: Record<string, Record<string, string>> = {
  tramites: { es: 'Trámites', de: 'Formalitäten', en: 'Paperwork', fr: 'Démarches', it: 'Pratiche', pt: 'Trâmites' },
  trabajo: { es: 'Trabajo', de: 'Arbeit', en: 'Work', fr: 'Travail', it: 'Lavoro', pt: 'Trabalho' },
  vivienda: { es: 'Vivienda', de: 'Wohnen', en: 'Housing', fr: 'Logement', it: 'Alloggio', pt: 'Moradia' },
  impuestos: { es: 'Impuestos', de: 'Steuern', en: 'Taxes', fr: 'Impôts', it: 'Tasse', pt: 'Impostos' },
  salud: { es: 'Salud', de: 'Gesundheit', en: 'Health', fr: 'Santé', it: 'Salute', pt: 'Saúde' },
  educacion: { es: 'Educación', de: 'Bildung', en: 'Education', fr: 'Éducation', it: 'Istruzione', pt: 'Educação' },
  vivir: { es: 'Vida diaria', de: 'Alltag', en: 'Daily life', fr: 'Vie quotidienne', it: 'Vita quotidiana', pt: 'Vida diária' },
};

const grupos = topicOrder
  .map((tema) => ({
    tema,
    label: topicLabels[tema][lang] || topicLabels[tema].es,
    guias: guiasDelIdioma.filter((g) => g.data.tema === tema),
  }))
  .filter((grupo) => grupo.guias.length > 0);

// Guías por país solo existen en es/en por ahora.
const porPaisLangs = ['es', 'en'];
const porPaisBanner: Record<string, { title: string; text: string; cta: string }> = {
  es: {
    title: 'Guías por país de origen',
    text: '¿Eres español, o vienes de Latinoamérica sin pasaporte europeo? Hay guías específicas para tu situación.',
    cta: 'Ver guías por país →',
  },
  en: {
    title: 'Guides by country of origin',
    text: 'Are you Spanish, or coming from Latin America without a European passport? There are guides specific to your situation.',
    cta: 'See guides by country →',
  },
};

const topicIcons: Record<string, string> = {
  tramites:
    '<rect x="4" y="3" width="16" height="18" rx="2"/><circle cx="9.5" cy="9" r="2"/><path d="M7 14.5c.5-1.6 1.4-2.4 2.5-2.4s2 .8 2.5 2.4"/><path d="M14.5 8h3M14.5 11h3"/>',
  trabajo:
    '<rect x="3" y="7.5" width="18" height="12" rx="2"/><path d="M8.5 7.5V6a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v1.5"/><path d="M3 12.5h18"/>',
  vivienda:
    '<path d="M4 11l8-7 8 7"/><path d="M6 9.5V20h12V9.5"/><path d="M10 20v-6h4v6"/>',
  impuestos:
    '<circle cx="7" cy="7" r="3"/><circle cx="17" cy="17" r="3"/><path d="M18 6L6 18"/>',
  salud:
    '<path d="M12 20s-7-4.4-9.5-9C.9 7.6 2.4 4 6 4c2 0 3.3 1 4 2.3.7-1.3 2-2.3 4-2.3 3.6 0 5.1 3.6 3.5 7-2.5 4.6-9.5 9-9.5 9z"/><path d="M7 11h2l1.2-2.5L11.5 13l1.3-2h2.2"/>',
  educacion:
    '<path d="M2 8.5L12 4l10 4.5L12 13z"/><path d="M6 10.7V16c0 1.4 2.7 2.5 6 2.5s6-1.1 6-2.5v-5.3"/><path d="M20 9.5v6"/>',
  vivir:
    '<rect x="3" y="10" width="18" height="8" rx="2"/><circle cx="7.5" cy="18" r="1.6"/><circle cx="16.5" cy="18" r="1.6"/><path d="M5 10V7a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v3"/><path d="M3 14h18"/>',
};
---
<Layout title={titulos[lang]} lang={lang} description={intros[lang] || intros.es}>
  <div class="hero">
    <h1>{titulos[lang]}</h1>
    <p>{intros[lang] || intros.es}</p>
  </div>

  {porPaisLangs.includes(lang) && (
    <a class="por-pais-banner" href={`/${lang}/por-pais`}>
      <div>
        <h2>{porPaisBanner[lang].title}</h2>
        <p>{porPaisBanner[lang].text}</p>
      </div>
      <span class="por-pais-cta">{porPaisBanner[lang].cta}</span>
    </a>
  )}

  {grupos.map((grupo) => (
    <section>
      <h2 class="topic-heading">
        {grupo.label} <span class="topic-count">{grupo.guias.length}</span>
      </h2>
      <div class="guide-grid">
        {grupo.guias.map((guia) => (
          <a class="card card-link" href={`/${lang}/guias/${guia.slug.split('/')[1]}`}>
            <span class="card-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={topicIcons[grupo.tema]} />
            </span>
            <h3>{guia.data.titulo}</h3>
            <p>{guia.data.resumen}</p>
            <span class="meta-row">{guia.data.minutosLectura} min</span>
          </a>
        ))}
      </div>
    </section>
  ))}
</Layout>

<style>
  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .guide-grid p {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
  }
  .guide-grid .meta-row {
    margin: 0;
  }
  .por-pais-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    background: var(--color-accent-soft);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    margin-bottom: var(--space-6);
    text-decoration: none;
    color: inherit;
  }
  .por-pais-banner h2 {
    margin: 0 0 var(--space-1);
  }
  .por-pais-banner p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }
  .por-pais-cta {
    color: var(--color-accent);
    font-weight: 600;
    white-space: nowrap;
  }
</style>
