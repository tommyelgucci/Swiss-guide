---

<Layout title={t.pageTitle} lang={lang} description={t.s4Body}>
  <div class="container">
    <a class="back-link" href={`/${lang}/`}>{t.backHome}</a>
    <h1>{t.heading}</h1>

    <h2>{t.s1Title}</h2>
    <p>{t.s1Body}</p>

    <h2>{t.s2Title}</h2>
    <ul>
      <li>{t.s2Guides}</li>
      <li>{t.s2Builder}</li>
      <li>{t.s2Analyzer}</li>
      <li>{t.s2Checklist}</li>
      <li>{t.s2Search}</li>
      <li>{t.s2Chat}</li>
    </ul>

    <h2>{t.s3Title}</h2>
    <p>{t.s3Body}</p>

    <h2>{t.s4Title}</h2>
    <p>{t.s4Body}</p>
  </div>
</Layout>
