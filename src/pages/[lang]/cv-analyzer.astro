---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  // Solo en/de/it/fr — inglés + los 3 idiomas oficiales de Suiza cubiertos
  // por la app. Nunca español, que no es idioma suizo.
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'it' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params as { lang: 'en' | 'de' | 'it' | 'fr' };

const t = {
  en: {
    pageTitle: 'CV Analyzer (ATS)',
    backHome: '← Back to home',
    heading: 'CV analyzer for the Swiss market',
    intro:
      'Upload your CV (PDF or DOCX, with selectable text, not a scan) and an AI evaluates it against Swiss recruiting and ATS conventions: a score, strengths, and what to improve.',
    fileLabel: 'CV file (PDF or DOCX, max 5 MB)',
    analyzeBtn: 'Analyze CV',
    analyzing: 'Analyzing…',
    disabledNotice:
      'The AI analyzer is not available right now (server configuration missing). The rest of the site works normally.',
    noFileError: 'Select a file first.',
    scoreLabel: 'Score',
    summaryLabel: 'Overall assessment',
    strengthsLabel: 'Strengths',
    issuesLabel: 'To improve',
    privacyNote:
      'The file is sent to the server only to extract text and generate the analysis; it is not stored.',
  },
  de: {
    pageTitle: 'Lebenslauf-Analyse (ATS)',
    backHome: '← Zur Startseite',
    heading: 'Lebenslauf-Analyse für den Schweizer Markt',
    intro:
      'Lade deinen Lebenslauf hoch (PDF oder DOCX, mit auswählbarem Text, kein Scan) und eine KI bewertet ihn nach Schweizer Rekrutierungs- und ATS-Konventionen: Punktzahl, Stärken und Verbesserungsvorschläge.',
    fileLabel: 'Lebenslauf-Datei (PDF oder DOCX, max. 5 MB)',
    analyzeBtn: 'Lebenslauf analysieren',
    analyzing: 'Wird analysiert…',
    disabledNotice:
      'Die KI-Analyse ist derzeit nicht verfügbar (Serverkonfiguration fehlt). Der Rest der Website funktioniert normal weiter.',
    noFileError: 'Wähle zuerst eine Datei aus.',
    scoreLabel: 'Punktzahl',
    summaryLabel: 'Gesamtbewertung',
    strengthsLabel: 'Stärken',
    issuesLabel: 'Verbesserungspotenzial',
    privacyNote:
      'Die Datei wird nur zur Textextraktion und Analyse an den Server gesendet; sie wird nicht gespeichert.',
  },
  it: {
    pageTitle: 'Analizzatore di CV (ATS)',
    backHome: '← Torna alla home',
    heading: 'Analizzatore di CV per il mercato svizzero',
    intro:
      'Carica il tuo CV (PDF o DOCX, con testo selezionabile, non una scansione) e un\'IA lo valuta secondo le convenzioni svizzere di reclutamento e ATS: punteggio, punti di forza e cosa migliorare.',
    fileLabel: 'File del CV (PDF o DOCX, max. 5 MB)',
    analyzeBtn: 'Analizza CV',
    analyzing: 'Analisi in corso…',
    disabledNotice:
      'L\'analizzatore IA non è disponibile in questo momento (manca la configurazione del server). Il resto del sito continua a funzionare normalmente.',
    noFileError: 'Seleziona prima un file.',
    scoreLabel: 'Punteggio',
    summaryLabel: 'Valutazione generale',
    strengthsLabel: 'Punti di forza',
    issuesLabel: 'Da migliorare',
    privacyNote:
      'Il file viene inviato al server solo per estrarre il testo e generare l\'analisi; non viene conservato.',
  },
  fr: {
    pageTitle: 'Analyseur de CV (ATS)',
    backHome: '← Retour à l\'accueil',
    heading: 'Analyseur de CV pour le marché suisse',
    intro:
      'Téléchargez votre CV (PDF ou DOCX, avec texte sélectionnable, pas un scan) et une IA l\'évalue selon les conventions suisses de recrutement et ATS : score, points forts et axes d\'amélioration.',
    fileLabel: 'Fichier du CV (PDF ou DOCX, max. 5 Mo)',
    analyzeBtn: 'Analyser le CV',
    analyzing: 'Analyse en cours…',
    disabledNotice:
      "L'analyseur IA n'est pas disponible pour le moment (configuration serveur manquante). Le reste du site fonctionne normalement.",
    noFileError: "Sélectionnez d'abord un fichier.",
    scoreLabel: 'Score',
    summaryLabel: 'Évaluation générale',
    strengthsLabel: 'Points forts',
    issuesLabel: 'À améliorer',
    privacyNote:
      "Le fichier est envoyé au serveur uniquement pour extraire le texte et générer l'analyse ; il n'est pas conservé.",
  },
}[lang];
---

<Layout title={t.pageTitle} lang={lang} availableLangs={['en', 'de', 'it', 'fr']}>
  <a class="back-link" href={`/${lang}/`}>{t.backHome}</a>
  <h1>{t.heading}</h1>
  <p>{t.intro}</p>

  <div id="disabled-notice" class="notice" hidden>{t.disabledNotice}</div>

  <form id="analyzer-form">
    <label>
      {t.fileLabel}
      <input type="file" id="cv-file" accept=".pdf,.docx" />
    </label>
    <button type="submit" id="analyze-btn">{t.analyzeBtn}</button>
    <p id="form-error" class="error" hidden></p>
  </form>

  <p class="privacy-note">{t.privacyNote}</p>

  <section id="result" class="card" hidden>
    <p class="eyebrow">{t.scoreLabel}</p>
    <p class="score-display"><span id="result-score"></span><span class="score-max">/100</span></p>
    <h3>{t.summaryLabel}</h3>
    <p id="result-summary"></p>
    <h3 id="strengths-heading" hidden>{t.strengthsLabel}</h3>
    <ul id="result-strengths"></ul>
    <h3>{t.issuesLabel}</h3>
    <ul id="result-issues"></ul>
  </section>
</Layout>

<script define:vars={{ t, lang }}>
  const form = document.getElementById('analyzer-form');
  const fileInput = document.getElementById('cv-file');
  const analyzeBtn = document.getElementById('analyze-btn');
  const formError = document.getElementById('form-error');
  const disabledNotice = document.getElementById('disabled-notice');
  const resultSection = document.getElementById('result');

  function showError(msg) {
    formError.textContent = msg;
    formError.hidden = false;
  }
  function clearError() {
    formError.hidden = true;
    formError.textContent = '';
  }

  fetch('/api/cv-analyzer/status')
    .then((r) => r.json())
    .then((data) => {
      if (!data.enabled) {
        disabledNotice.hidden = false;
        analyzeBtn.disabled = true;
      }
    })
    .catch(() => {
      disabledNotice.hidden = false;
      analyzeBtn.disabled = true;
    });

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    clearError();
    resultSection.hidden = true;

    const file = fileInput.files?.[0];
    if (!file) {
      showError(t.noFileError);
      return;
    }

    const formData = new FormData();
    formData.append('cv', file);
    formData.append('lang', lang);

    analyzeBtn.disabled = true;
    const originalLabel = analyzeBtn.textContent;
    analyzeBtn.textContent = t.analyzing;

    try {
      const res = await fetch('/api/cv-analyzer/analyze', {
        method: 'POST',
        body: formData,
      });
      const data = await res.json();
      if (!res.ok) {
        showError(data.error || `Error ${res.status}`);
        return;
      }
      renderResult(data);
    } catch (err) {
      showError(err instanceof Error ? err.message : String(err));
    } finally {
      analyzeBtn.disabled = false;
      analyzeBtn.textContent = originalLabel;
    }
  });

  function renderResult(data) {
    document.getElementById('result-score').textContent = data.score;
    document.getElementById('result-summary').textContent = data.summary;

    const strengthsList = document.getElementById('result-strengths');
    const strengthsHeading = document.getElementById('strengths-heading');
    strengthsList.innerHTML = '';
    if (data.strengths?.length) {
      strengthsHeading.hidden = false;
      data.strengths.forEach((s) => {
        const li = document.createElement('li');
        li.textContent = s;
        strengthsList.appendChild(li);
      });
    } else {
      strengthsHeading.hidden = true;
    }

    const issuesList = document.getElementById('result-issues');
    issuesList.innerHTML = '';
    (data.issues || []).forEach((issue) => {
      const li = document.createElement('li');
      const strong = document.createElement('strong');
      strong.textContent = `${issue.category}: `;
      li.appendChild(strong);
      li.appendChild(document.createTextNode(issue.detail));
      const suggestion = document.createElement('p');
      suggestion.className = 'suggestion';
      suggestion.textContent = issue.suggestion;
      li.appendChild(suggestion);
      issuesList.appendChild(li);
    });

    resultSection.hidden = false;
  }
</script>

<style>
  .notice {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-5);
    background: var(--color-surface);
  }
  form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 480px;
    margin-bottom: var(--space-3);
  }
  .privacy-note {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    max-width: 480px;
  }
  .error {
    color: var(--color-danger);
    font-weight: 600;
  }
  .score-display {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin: 0 0 var(--space-4);
  }
  .score-max {
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text-secondary);
  }
  :global(#result-issues li),
  :global(#result-strengths li) {
    margin-bottom: var(--space-3);
  }
  :global(.suggestion) {
    margin: var(--space-1) 0 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }
</style>
