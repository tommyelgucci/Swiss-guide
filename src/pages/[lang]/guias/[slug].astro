---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const todasLasGuias = await getCollection('guias-universales');
  return todasLasGuias.map((guia) => {
    const [lang, slug] = guia.slug.split('/');
    return {
      params: { lang, slug },
      props: { guia },
    };
  });
}

const { guia } = Astro.props;
const { lang } = Astro.params;
const { Content } = await guia.render();

const backLabels: Record<string, string> = {
  es: '← Todas las guías',
  de: '← Alle Leitfäden',
  en: '← All guides',
  fr: '← Tous les guides',
  it: '← Tutte le guide',
  pt: '← Todos os guias',
};
---
<Layout title={guia.data.titulo} lang={lang}>
  <div class="container">
    <a class="back-link" href={`/${lang}/`}>{backLabels[lang] || backLabels.es}</a>
    <article>
      <h1>{guia.data.titulo}</h1>
      <p class="meta-row">
        {guia.data.minutosLectura} min · {guia.data.fechaActualizacion.toLocaleDateString(lang)}
      </p>
      <Content />
    </article>
  </div>
</Layout>
