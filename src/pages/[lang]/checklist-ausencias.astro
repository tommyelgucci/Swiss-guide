  // que sí incluye los 6 idiomas — mismo criterio que la calculadora de
  // impuestos.
  const idiomas = ['es', 'de', 'en', 'fr', 'it', 'pt'];
  return idiomas.map((lang) => ({ params: { lang } }));
}

