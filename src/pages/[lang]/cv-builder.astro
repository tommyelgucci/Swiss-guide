  // cubre esta app. Nunca español: no es idioma oficial suizo y estas
  // herramientas son específicamente para instalarse en Suiza.
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'de' } },
    { params: { lang: 'it' } },
    { params: { lang: 'fr' } },
  ];
}

