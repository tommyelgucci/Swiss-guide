---
interface Props {
  lang: string;
}
const { lang } = Astro.props;

const t: Record<string, { open: string; placeholder: string; noResults: string; close: string }> = {
  es: { open: 'Buscar', placeholder: 'Busca un trámite, tema o herramienta…', noResults: 'Sin resultados. Prueba con otra palabra.', close: 'Cerrar' },
  de: { open: 'Suchen', placeholder: 'Suche nach einem Thema oder Tool…', noResults: 'Keine Ergebnisse. Versuche einen anderen Begriff.', close: 'Schliessen' },
  en: { open: 'Search', placeholder: 'Search for a topic or tool…', noResults: 'No results. Try a different word.', close: 'Close' },
  fr: { open: 'Rechercher', placeholder: 'Cherchez un sujet ou un outil…', noResults: 'Aucun résultat. Essayez un autre mot.', close: 'Fermer' },
  it: { open: 'Cerca', placeholder: 'Cerca un argomento o uno strumento…', noResults: 'Nessun risultato. Prova un\'altra parola.', close: 'Chiudi' },
  pt: { open: 'Buscar', placeholder: 'Busque um tema ou ferramenta…', noResults: 'Sem resultados. Tente outra palavra.', close: 'Fechar' },
}[lang] || { open: 'Search', placeholder: 'Search…', noResults: 'No results.', close: 'Close' };
---
<button id="site-search-open" class="search-open-btn" aria-label={t.open} title={t.open}>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
</button>

<div id="site-search-overlay" class="search-overlay" hidden>
  <div class="search-panel">
    <div class="search-input-row">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      <input id="site-search-input" type="search" placeholder={t.placeholder} autocomplete="off" />
      <button id="site-search-close" aria-label={t.close}>✕</button>
    </div>
    <ul id="site-search-results" class="search-results"></ul>
    <p id="site-search-empty" class="search-empty" hidden>{t.noResults}</p>
  </div>
</div>

<script type="application/json" id="site-search-i18n" set:html={JSON.stringify({ lang, noResults: t.noResults })} />

<script>
  import { searchEntries } from '../lib/searchIndex.js';

  const { lang, noResults } = JSON.parse(document.getElementById('site-search-i18n').textContent);
  const openBtn = document.getElementById('site-search-open');
  const closeBtn = document.getElementById('site-search-close');
  const overlay = document.getElementById('site-search-overlay');
  const input = document.getElementById('site-search-input');
  const resultsEl = document.getElementById('site-search-results');
  const emptyEl = document.getElementById('site-search-empty');

  let index = null;

  async function loadIndex() {
    if (index) return index;
    const res = await fetch('/search-index.json');
    index = await res.json();
    return index;
  }

  function render(query) {
    if (!query.trim()) {
      resultsEl.innerHTML = '';
      emptyEl.hidden = true;
      return;
    }
    const matches = searchEntries(index || [], lang, query);
    resultsEl.innerHTML = '';
    emptyEl.hidden = matches.length > 0 || !query.trim();
    matches.forEach((m) => {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = m.url;
      a.innerHTML = `<strong>${m.title}</strong>${m.text ? `<span>${m.text}</span>` : ''}`;
      li.appendChild(a);
      resultsEl.appendChild(li);
    });
  }

  async function open() {
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    await loadIndex();
    input.value = '';
    resultsEl.innerHTML = '';
    emptyEl.hidden = true;
    input.focus();
  }

  function close() {
    overlay.hidden = true;
    document.body.style.overflow = '';
  }

  openBtn.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) close();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay.hidden) close();
    if ((e.key === '/' || (e.metaKey && e.key === 'k') || (e.ctrlKey && e.key === 'k')) && overlay.hidden && document.activeElement.tagName !== 'INPUT') {
      e.preventDefault();
      open();
    }
  });
  input.addEventListener('input', () => render(input.value));
</script>

<style>
  .search-open-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
    padding: 0;
  }
  .search-open-btn:hover {
    border-color: var(--color-accent);
  }
  .search-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 10vh 1rem 1rem;
    z-index: 100;
  }
  .search-overlay[hidden] {
    display: none;
  }
  .search-panel {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 560px;
    max-height: 70vh;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .search-input-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }
  .search-input-row input {
    flex: 1;
    border: none;
    outline: none;
    font-size: var(--text-lg);
    background: transparent;
    color: var(--color-text);
    min-height: auto;
    padding: 0;
  }
  .search-input-row button {
    background: none;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    font-size: var(--text-lg);
    padding: 0 var(--space-1);
  }
  .search-results {
    list-style: none;
    margin: 0;
    padding: var(--space-2);
    overflow-y: auto;
  }
  .search-results li a {
    display: block;
    padding: var(--space-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--color-text);
  }
  .search-results li a:hover {
    background: var(--color-accent-soft);
  }
  .search-results li a strong {
    display: block;
  }
  .search-results li a span {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-top: var(--space-1);
  }
  .search-empty {
    padding: var(--space-4);
    color: var(--color-text-secondary);
    text-align: center;
  }
</style>
