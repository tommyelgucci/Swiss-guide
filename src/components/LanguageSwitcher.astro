---
interface Props {
  currentLang: string;
  // Idiomas en los que esta página concreta existe de verdad. Por defecto,
  // los 6 — pero páginas que solo tienen contenido en ES/EN (herramientas,
  // guías no traducidas) deben pasar explícitamente cuáles.
  availableLangs?: string[];
}
const { currentLang, availableLangs } = Astro.props;

const todosLosIdiomas = [
  { code: 'es', label: 'Español' },
  { code: 'de', label: 'Deutsch' },
  { code: 'en', label: 'English' },
  { code: 'fr', label: 'Français' },
  { code: 'it', label: 'Italiano' },
  { code: 'pt', label: 'Português' },
];

const idiomas = availableLangs
  ? todosLosIdiomas.filter((idioma) => availableLangs.includes(idioma.code))
  : todosLosIdiomas;

// Reemplaza el segmento de idioma en la URL actual, ej:
// /es/guias/lamal -> /de/guias/lamal
const pathSinIdioma = Astro.url.pathname.replace(`/${currentLang}/`, '/');
---
<nav class="lang-switcher" aria-label="Selector de idioma">
  {idiomas.map((idioma) => (
    <a
      href={`/${idioma.code}${pathSinIdioma}`}
      aria-current={idioma.code === currentLang ? 'page' : undefined}
    >
      {idioma.label}
    </a>
  ))}
</nav>
