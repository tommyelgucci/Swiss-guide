---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import '../styles/global.css';

interface Props {
  title: string;
  lang: string;
  availableLangs?: string[];
  description?: string;
}
const { title, lang, availableLangs, description } = Astro.props;

const defaultDescriptions: Record<string, string> = {
  es: 'Guías prácticas para vivir y trabajar en Suiza — trámites, vivienda, trabajo, impuestos y salud, en 6 idiomas.',
  de: 'Praktische Leitfäden für das Leben und Arbeiten in der Schweiz — Formalitäten, Wohnen, Arbeit, Steuern und Gesundheit, in 6 Sprachen.',
  en: 'Practical guides to living and working in Switzerland — paperwork, housing, work, taxes, and health, in 6 languages.',
  fr: 'Guides pratiques pour vivre et travailler en Suisse — démarches, logement, travail, impôts et santé, en 6 langues.',
  it: 'Guide pratiche per vivere e lavorare in Svizzera — pratiche, alloggio, lavoro, tasse e salute, in 6 lingue.',
  pt: 'Guias práticos para viver e trabalhar na Suíça — trâmites, moradia, trabalho, impostos e saúde, em 6 idiomas.',
};
const pageDescription = description || defaultDescriptions[lang] || defaultDescriptions.es;

const ogLocales: Record<string, string> = {
  es: 'es_ES',
  de: 'de_CH',
  en: 'en_US',
  fr: 'fr_CH',
  it: 'it_CH',
  pt: 'pt_PT',
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL('/og-image.png', Astro.site).toString();

// El creador/analizador de CV solo existen en en/de/it/fr (idiomas oficiales
// de Suiza + inglés) — nunca en español, que no es idioma suizo. Si la
// página actual está en un idioma sin herramientas (es, pt), el enlace cae
// a inglés.
const toolLangs = ['en', 'de', 'it', 'fr'];
const toolsLang = toolLangs.includes(lang) ? lang : 'en';

const footerText: Record<string, string> = {
  es: 'FirstStepsinCH — guías para extranjeros en Suiza.',
  de: 'FirstStepsinCH — Leitfäden für Ausländer in der Schweiz.',
  en: 'FirstStepsinCH — guides for foreigners in Switzerland.',
  fr: 'FirstStepsinCH — guides pour les étrangers en Suisse.',
  it: 'FirstStepsinCH — guide per stranieri in Svizzera.',
  pt: 'FirstStepsinCH — guias para estrangeiros na Suíça.',
};

const legalLabels: Record<string, string> = {
  es: 'Aviso legal y privacidad',
  de: 'Impressum und Datenschutz',
  en: 'Legal notice and privacy',
  fr: 'Mentions légales et confidentialité',
  it: 'Note legali e privacy',
  pt: 'Aviso legal e privacidade',
};

const toolLabels: Record<string, { builder: string; analyzer: string; checklist: string }> = {
  en: { builder: 'CV builder', analyzer: 'CV analyzer', checklist: 'Absence checklist' },
  de: { builder: 'Lebenslauf-Ersteller', analyzer: 'Lebenslauf-Analyse', checklist: 'Abwesenheits-Checkliste' },
  it: { builder: 'Creatore di CV', analyzer: 'Analizzatore di CV', checklist: 'Checklist assenze' },
  fr: { builder: 'Créateur de CV', analyzer: 'Analyseur de CV', checklist: "Checklist d'absence" },
};
const labels = toolLabels[toolsLang];

// La calculadora de impuestos, a diferencia del CV/checklist, sirve a
// quien YA vive en Suiza — sí existe en los 6 idiomas, sin fallback.
const taxCalcLabels: Record<string, string> = {
  es: 'Calculadora de impuestos',
  de: 'Steuerrechner',
  en: 'Tax calculator',
  fr: "Calculateur d'impôts",
  it: 'Calcolatore imposte',
  pt: 'Calculadora de impostos',
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="FirstStepsinCH" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocales[lang] || ogLocales.es} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="site-brand" href={`/${lang}/`}>
          <svg class="brand-mark" width="36" height="36" viewBox="0 0 60 60" aria-hidden="true">
            <rect width="60" height="60" rx="14" fill="var(--color-accent)" />
            <g transform="translate(11.25,10.08)">
              <svg width="37.5" height="37.5" viewBox="0 0 60 60" fill="none">
                <path d="M8 38 L8 22 Q8 20 9.5 18.5 L28 3 Q30 1.5 32 3 L50.5 18.5 Q52 20 52 22 L52 38" stroke="var(--color-accent-contrast)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                <line x1="8" y1="38" x2="52" y2="38" stroke="var(--color-accent-contrast)" stroke-width="5" stroke-linecap="round" />
                <rect x="25" y="26" width="10" height="12" fill="var(--color-accent-contrast)" />
                <rect x="28" y="29" width="4" height="1.6" fill="var(--color-accent)" />
                <rect x="29.2" y="27.8" width="1.6" height="4.4" fill="var(--color-accent)" />
                <ellipse cx="14" cy="48" rx="3.5" ry="2.3" fill="var(--color-accent-contrast)" transform="rotate(-20 14 48)" />
                <ellipse cx="20" cy="43" rx="3.5" ry="2.3" fill="var(--color-accent-contrast)" transform="rotate(-20 20 43)" />
              </svg>
            </g>
          </svg>
          <span>FirstStepsinCH</span>
        </a>
        <nav class="tools-nav" aria-label="Herramientas">
          <a href={`/${toolsLang}/cv-builder`}>{labels.builder}</a>
          <a href={`/${toolsLang}/cv-analyzer`}>{labels.analyzer}</a>
          <a href={`/${toolsLang}/checklist-ausencias`}>{labels.checklist}</a>
          <a href={`/${lang}/tax-calculator`}>{taxCalcLabels[lang] || taxCalcLabels.en}</a>
        </nav>
        <LanguageSwitcher currentLang={lang} availableLangs={availableLangs} />
      </div>
    </header>
    <main class="container-wide">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container-wide">
        <p>{footerText[lang] || footerText.es}</p>
        <p><a href={`/${lang}/legal`}>{legalLabels[lang] || legalLabels.es}</a></p>
      </div>
    </footer>
  </body>
</html>
