---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title: string;
  lang: string;
}
const { title, lang } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <LanguageSwitcher currentLang={lang} />
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
