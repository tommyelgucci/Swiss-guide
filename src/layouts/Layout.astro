---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title: string;
  lang: string;
}
const { title, lang } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <LanguageSwitcher currentLang={lang} />
      <nav aria-label="Herramientas">
        <a href={`/${lang === 'en' ? 'en' : 'es'}/cv-builder`}>
          {lang === 'en' ? 'Swiss CV builder' : 'Creador de CV suizo'}
        </a>
        <a href={`/${lang === 'en' ? 'en' : 'es'}/cv-analyzer`}>
          {lang === 'en' ? 'CV analyzer (ATS)' : 'Analizador de CV (ATS)'}
        </a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
